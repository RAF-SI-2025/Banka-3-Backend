# Postgres
POSTGRES_USER=banka
POSTGRES_PASSWORD=banka
POSTGRES_DB=banka
POSTGRES_PORT=5432

# Replication (BonusPartitionReplication / #286)
POSTGRES_REPLICATION_USER=replicator
POSTGRES_REPLICATION_PASSWORD=replicator_pass
POSTGRES_REPLICATION_SLOT=banka_replica_slot
POSTGRES_REPLICA_PORT=5433

# Read-replica routing. Each service holds a routed *postgres.DB: writes
# and transactions go to the primary (DATABASE_URL), reads marked
# postgres.WithRead(ctx) — list/get-catalog/report queries — go to the
# replica (DATABASE_READ_URL). docker-compose defaults this to the local
# streaming standby (postgres_replica), so `make up` gets prod-parity
# routing with no extra step. Override here to point elsewhere, or set it
# empty to collapse all reads back onto the primary:
# DATABASE_READ_URL=
# DATABASE_READ_URL=postgres://banka:banka@banka-postgres_replica-1:5432/banka?sslmode=disable

# Redis
REDIS_PASSWORD=banka
REDIS_PORT=6379

# Bank identity (changes per running bank in c5)
BANK_CODE=333
BANK_NAME="Banka 3"

# Server-side pepper for HMAC-SHA256 of card CVVs. Required in prod;
# rotate by re-issuing all cards (the digest depends on the pepper).
BANK_CVV_PEPPER=dev-cvv-pepper-change-in-prod

# JWT
JWT_SIGNING_KEY=change-me-in-prod-please-this-is-only-for-dev
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
# Refresh-token lifetime for mobile logins (long_lived_session — spec
# p.84, the mobile app has no session interval). Default ~1y if unset.
JWT_MOBILE_REFRESH_TTL=8760h

# Service ports — gRPC
USER_GRPC_PORT=50051
BANK_GRPC_PORT=50052
TRADING_GRPC_PORT=50053
EXCHANGE_GRPC_PORT=50054
NOTIFICATION_GRPC_PORT=50055

# Service ports — probes (k8s liveness/readiness)
USER_PROBE_PORT=8081
BANK_PROBE_PORT=8082
TRADING_PROBE_PORT=8083
EXCHANGE_PROBE_PORT=8084
NOTIFICATION_PROBE_PORT=8085
GATEWAY_PROBE_PORT=8086

# Gateway
GATEWAY_HTTP_PORT=8080

# Inter-service gRPC addresses (for local dev compose). Each service
# resolves a partner by its full container name (`banka-bank-1` etc).
# Short names like `bank` only work for a stack on its own — the c5
# partner overlay also calls a service named `bank`, and Docker DNS
# resolves the short name non-deterministically on the shared `banka`
# network.
USER_GRPC_ADDR=banka-user-1:50051
BANK_GRPC_ADDR=banka-bank-1:50051
TRADING_GRPC_ADDR=banka-trading-1:50051
EXCHANGE_GRPC_ADDR=banka-exchange-1:50051
NOTIFICATION_GRPC_ADDR=banka-notification-1:50051

# Email — set SMTP_HOST to send real emails; leave empty to log to stdout
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@banka.local
SMTP_TLS=false

# Public URL of the SPA (used in activation/reset email links)
WEB_BASE_URL=http://localhost:5173

# Token TTLs (Go duration syntax)
ACTIVATION_TTL=24h
RESET_TTL=15m

# Trading service knobs (c3 spec p.55-56). EXECUTION_TICK_INTERVAL is
# how often the partial-fill worker walks active orders; lower it in
# tests so fills land faster, leave the default in dev. FX_COMMISSION
# is the menjačnica fee rate the bank charges clients on cross-currency
# legs (decimal string).
EXECUTION_TICK_INTERVAL=10s
FX_COMMISSION=0.005

# Menjačnica FX rate feed. The exchange service pulls mid rates from
# open.er-api.com (free, no API key) into "exchange".fx_rates; the
# first fetch runs at boot, then every FX_FEED_INTERVAL. Set 0 to
# disable the background feed entirely. FX_FEED_SPREAD is the symmetric
# bid/ask offset around the upstream mid (0.01 → ±1%); the bank's
# profit is the commission, not the spread.
FX_FEED_INTERVAL=5m
FX_FEED_SPREAD=0.01

# SAGA fault injection for cypress c4-tests. When true, the trading
# service honours the X-Saga-Force-Fail / -Kind / -Compensate-Fail
# request headers (forwarded by grpc-gateway as grpcgateway-x-saga-*
# metadata) and forces the named step's Forward / Compensate to return
# a synthetic error. Off in production — the surface lets the cypress
# scenarios drive internal SAGA failure modes (S4/6/7/9) that have no
# natural FE trigger. Read by services/trading/internal/app/app.go
# into service.Config.SagaDebugFaultInjection; consulted at saga.Start
# kickoff in each *_saga.go.
SAGA_DEBUG_FAULT_INJECTION=true

# QA-adjustable clock (pkg/clock). When true, the gateway exposes
# POST /api/v1/_debug/clock {offset:"24h"} (any time.ParseDuration
# string) and the trading + bank service Adjustable clocks poll
# Redis for the offset every 5 s. Off in production; cypress relies
# on it for cron + expiry coverage.
CLOCK_DEBUG=true

# Alpha Vantage market-data feed (spec p.40, p.42). When the API key is
# unset, the trading service skips the refresh cron and listings hold
# at their seeded prices — fine for offline dev. Free-tier quota is
# 25 requests/day and 5/min; defaults below stay inside both. Get a key
# at https://www.alphavantage.co/support/#api-key.
ALPHAVANTAGE_API_KEY=
MARKET_DATA_REFRESH_INTERVAL=6h
MARKET_DATA_PAUSE=13s

# Price-alert sweep cadence (todoSpec C3 S26-S29). The scheduler fires
# RunPriceAlertSweep on this interval; each pass checks every active
# alert against its security's current price.
PRICE_ALERT_TICK=1m
STOCK_BIDASK_SPREAD=0.001

# Celina 5 — inter-bank protocol.
#
# BANK_ROUTING_NUMBER identifies us to partner banks (echoed in every
# outbound request). Spec example uses 333 for "Banka 3".
#
# INTERBANK_ROUTES is a comma-separated list of "code:url" pairs naming
# the partner banks we talk to. Empty means no cross-bank outbound — the
# trading service then nil-checks PartnerOTC at every call site.
#
# INTERBANK_API_KEY is the key the gateway validates on INBOUND partner
# calls (the key WE issued — partners send it), and the default trading
# uses OUTBOUND when a partner has no specific key below. The dev value
# lets the mock-partner container talk back without extra setup.
#
# INTERBANK_PARTNER_KEYS is an optional comma-separated list of
# "code:key" pairs giving the X-Api-Key each partner expects from us on
# OUTBOUND (the key THEY issued). Overrides INTERBANK_API_KEY per bank,
# so our inbound key and each partner's outbound key can differ. Example:
#   INTERBANK_PARTNER_KEYS=444:bank4-secret-key
#
# INTERBANK_SIGN_KEY is the shared secret for the celina-5 digital
# signature (pkg/signature, HMAC-SHA256). When set, every OUTBOUND
# inter-bank request is stamped with X-Timestamp + X-Content-Hash +
# X-Signature, and the gateway VERIFIES those headers on INBOUND partner
# payments (rejecting bad/missing/stale signatures with 401). Leave empty
# for a dev stack: both sides skip signing so unsigned traffic still
# works (same env-driven gating as SMTP). Both banks in a pair must agree
# on the same value.
BANK_ROUTING_NUMBER=333
INTERBANK_ROUTES=
INTERBANK_API_KEY=dev-outbound-banka3
INTERBANK_PARTNER_KEYS=
INTERBANK_SIGN_KEY=

# Scheduler service — the single non-replicatable driver of every
# cluster-wide cron + worker. It calls the bank/trading/exchange trigger
# RPCs on a schedule; those services run with JOBS_ENABLED=false (set per
# service in docker-compose) and stay stateless + horizontally-scalable.
#
# JOBS_ENABLED gates the in-process jobs in bank/trading/exchange. The
# compose file defaults it to false (scheduler owns them). Set true ONLY
# if you also remove the scheduler — otherwise jobs fire twice.
# JOBS_ENABLED=false
#
# LEADER_ELECTION makes the scheduler contend for a k8s Lease so 2+
# replicas can run with instant failover (production). Off locally — a
# single scheduler instance is the sole leader. The k8s path also reads
# POD_NAMESPACE + LEASE_NAME (defaults: raf-banka / scheduler-leader).
# LEADER_ELECTION=false

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
